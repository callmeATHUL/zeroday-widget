/* ZERODAY Minimal Sticky Note Style */

QWidget {
    font-family: 'Inter', 'Roboto', 'Segoe UI', sans-serif;
    color: #e8eaed;
}

#MainWidget {
    background-color: rgba(20, 20, 20, 0.9); /* Slightly darker, more solid sticky feel */
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
}

#Header {
    margin-top: 5px;
}

#Title {
    font-size: 20px;
    font-weight: 800;
    color: #ffffff; /* Absolute White as requested */
    qproperty-alignment: 'AlignCenter';
    letter-spacing: 1px;
}

#Subtitle {
    font-size: 11px;
    color: #888888;
    margin-bottom: 2px;
    qproperty-alignment: 'AlignCenter';
    text-transform: uppercase;
}

#Divider {
    background-color: rgba(255, 255, 255, 0.05);
    max-height: 1px;
    margin: 5px 10px;
}

QScrollArea {
    border: none;
    background: transparent;
}

#ScrollContent {
    background: transparent;
}

#TaskRow {
    background-color: rgba(255, 255, 255, 0.03);
    border-radius: 6px;
    margin: 2px 10px;
    padding: 4px 8px;
}

#TaskDot {
    background-color: #ffffff;
    max-width: 6px;
    max-height: 6px;
    border-radius: 3px;
    margin-right: 8px;
    opacity: 0.7;
}

#TaskLabel {
    font-size: 13px;
    color: #d1d1d1;
}

#DelBtn {
    background-color: transparent;
    color: #666666;
    font-size: 16px;
    border: none;
    padding: 0 4px;
}

#DelBtn:hover {
    color: #ff6b6b;
}

#InputRow {
    margin: 5px 10px 10px 10px;
}

#TaskInput {
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 6px;
    padding: 6px 10px;
    font-size: 13px;
    color: #ffffff;
}

#TaskInput:focus {
    border: 1px solid rgba(255, 255, 255, 0.3);
}

#AddBtn {
    background-color: #ffffff;
    color: #000000;
    font-size: 18px;
    font-weight: bold;
    border-radius: 6px;
    min-width: 32px;
    min-height: 30px;
}

#AddBtn:hover {
    background-color: #e0e0e0;
}

/* Scrollbar Refinement */
QScrollBar:vertical {
    border: none;
    background: transparent;
    width: 4px;
}

QScrollBar::handle:vertical {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 2px;
}
